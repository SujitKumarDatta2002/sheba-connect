# Server Configuration
PORT=5000

# MongoDB Connection String (replace with your MongoDB Atlas URI)
MONGO_URI=mongodb://username:password@host:port/database?options

# JWT Secret for authentication (generate a random string)
JWT_SECRET=your-jwt-secret-key-here

# Hugging Face API Token (optional, for AI features)
HF_API_TOKEN=your_hf_api_token_here

# ── Notification Provider ────────────────────────────────────────────────────
# Options: 'whatsapp' | 'twilio' | 'alphasms'
SMS_PROVIDER=whatsapp

# ── Twilio SMS/WhatsApp Credentials ──────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Alpha SMS (Bangladesh) ──────────────────────────────────────────────────
# Optional - for Bangladeshi SMS service
ALPHA_API_KEY=your_alpha_sms_api_key_here
ALPHA_SENDER_ID=
